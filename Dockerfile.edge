FROM rust:1.94-bookworm AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates crates
RUN cargo build --release -p driftbase-edge

FROM caddy:2-alpine
RUN apk add --no-cache ca-certificates iproute2 iptables wireguard-tools
COPY --from=builder /build/target/release/driftbase-edge /usr/local/bin/driftbase-edge
ENTRYPOINT ["/usr/local/bin/driftbase-edge"]
